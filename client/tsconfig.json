{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "outDir": null,
    "rootDir": null,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
